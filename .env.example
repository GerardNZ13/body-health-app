# Optional: set a default Gemini API key so insights work without entering it in the app.
# Get a free key at https://aistudio.google.com/apikey
# Copy this file to .env and add your key (do not commit .env).
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Fit steps sync. Create OAuth 2.0 Web client in Google Cloud, enable Fitness API.
# If you use Samsung Health, sync it to Google Fit on your phone to pull steps here.
# VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
